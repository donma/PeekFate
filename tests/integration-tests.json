{
  "testCases": [
    {
      "id": 1,
      "description": "隱私功能測試 - 預設不儲存客戶資料",
      "type": "privacy",
      "expected": {
        "defaultNotSave": true,
        "rememberOnlyWhenChecked": true,
        "clearDataDeletesStorage": true
      }
    },
    {
      "id": 2,
      "description": "PWA 功能測試 - Manifest 可讀",
      "type": "pwa",
      "expected": {
        "manifestReadable": true,
        "serviceWorkerRegistered": true,
        "cacheStorageHasData": true,
        "offlineCanOpen": true
      }
    },
    {
      "id": 3,
      "description": "性能測試 - 首屏加載時間",
      "type": "performance",
      "expected": {
        "firstContentfulPaint": "<2000ms",
        "largestContentfulPaint": "<2500ms",
        "cumulativeLayoutShift": "<0.1",
        "firstInputDelay": "<100ms",
        "timeToInteractive": "<3500ms"
      }
    },
    {
      "id": 4,
      "description": "端到端測試 - 完整用戶流程",
      "type": "e2e",
      "expected": {
        "pageLoads": true,
        "formSubmissionWorks": true,
        "navigationWorks": true,
        "errorHandlingWorks": true,
        "responsiveDesignWorks": true
      }
    },
    {
      "id": 5,
      "description": "隱私功能測試 - LocalStorage 清除驗證",
      "type": "privacy",
      "expected": {
        "clearButtonVisible": true,
        "clearRemovesAllKeys": true,
        "clearConfirmationShown": true,
        "afterClearStateEmpty": true
      }
    },
    {
      "id": 6,
      "description": "PWA 功能測試 - Service Worker 更新",
      "type": "pwa",
      "expected": {
        "updateDetected": true,
        "updatePromptShown": true,
        "skipWaitingWorks": true,
        "clientsClaimWorks": true
      }
    },
    {
      "id": 7,
      "description": "性能測試 - 資源加載優化",
      "type": "performance",
      "expected": {
        "imageOptimized": true,
        "cssMinified": true,
        "jsMinified": true,
        "gzipEnabled": true,
        "browserCaching": true
      }
    },
    {
      "id": 8,
      "description": "端到端測試 - 表單驗證",
      "type": "e2e",
      "expected": {
        "requiredFieldValidation": true,
        "emailFormatValidation": true,
        "maxLengthValidation": true,
        "errorMessageDisplayed": true,
        "successMessageDisplayed": true
      }
    },
    {
      "id": 9,
      "description": "隱私功能測試 - Cookie 政策",
      "type": "privacy",
      "expected": {
        "cookieConsentBannerShown": true,
        "acceptCookiesWorks": true,
        "rejectCookiesWorks": true,
        "cookiePolicyAccessible": true
      }
    },
    {
      "id": 10,
      "description": "PWA 功能測試 - 離線功能",
      "type": "pwa",
      "expected": {
        "offlinePageShown": true,
        "cachedContentAccessible": true,
        "offlineFormQueued": true,
        "onlineSyncWorks": true
      }
    },
    {
      "id": 11,
      "description": "性能測試 - 動畫流暢度",
      "type": "performance",
      "expected": {
        "frameRate60fps": true,
        "noJankyAnimations": true,
        "smoothScrolling": true,
        "transitionPerformance": true
      }
    },
    {
      "id": 12,
      "description": "端到端測試 - 響應式設計",
      "type": "e2e",
      "expected": {
        "mobileLayout": true,
        "tabletLayout": true,
        "desktopLayout": true,
        "touchInteractions": true,
        "viewportMetaTag": true
      }
    },
    {
      "id": 13,
      "description": "隱私功能測試 - 數據加密",
      "type": "privacy",
      "expected": {
        "sensitiveDataEncrypted": true,
        "httpsEnforced": true,
        "noMixedContent": true,
        "secureHeadersPresent": true
      }
    },
    {
      "id": 14,
      "description": "PWA 功能測試 - 安裝提示",
      "type": "pwa",
      "expected": {
        "installPromptShown": true,
        "installSuccess": true,
        "appIconAdded": true,
        "splashScreenShown": true
      }
    },
    {
      "id": 15,
      "description": "性能測試 - 內存使用",
      "type": "performance",
      "expected": {
        "noMemoryLeaks": true,
        "memoryUsageStable": true,
        "garbageCollectionWorks": true,
        "domNodesOptimized": true
      }
    },
    {
      "id": 16,
      "description": "端到端測試 - 錯誤處理",
      "type": "e2e",
      "expected": {
        "404PageShown": true,
        "500ErrorHandled": true,
        "networkErrorHandled": true,
        "timeoutHandled": true,
        "userFriendlyMessages": true
      }
    },
    {
      "id": 17,
      "description": "隱私功能測試 - 第三方追蹤",
      "type": "privacy",
      "expected": {
        "noUnwantedTrackers": true,
        "analyticsAnonymized": true,
        "thirdPartyScriptsLimited": true,
        "privacyPolicyAccessible": true
      }
    },
    {
      "id": 18,
      "description": "PWA 功能測試 - 推送通知",
      "type": "pwa",
      "expected": {
        "permissionRequested": true,
        "notificationShown": true,
        "clickNotificationWorks": true,
        "unsubscribeWorks": true
      }
    },
    {
      "id": 19,
      "description": "性能測試 - 網絡優化",
      "type": "performance",
      "expected": {
        "http2Enabled": true,
        "preloadCriticalResources": true,
        "dnsPrefetch": true,
        "connectionPooling": true
      }
    },
    {
      "id": 20,
      "description": "端到端測試 - 無障礙功能",
      "type": "e2e",
      "expected": {
        "keyboardNavigation": true,
        "screenReaderCompatible": true,
        "ariaLabelsPresent": true,
        "colorContrastSufficient": true,
        "focusVisible": true
      }
    }
  ],
