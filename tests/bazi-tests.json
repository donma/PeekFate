    "pillarStructure": {
      "requiredFields": ["stem", "branch", "name", "nayin", "label"],
      "optionalFields": ["year", "solarTerm", "isUnknown"]
    },
    "dayMasterStructure": {
      "requiredFields": ["stem", "element", "elementName", "yinYang", "label"]
    },
    "tenGodsStructure": {
      "requiredFields": ["name", "type", "description"],
      "validTypes": ["peer", "output", "wealth", "officer", "resource", "unknown"]
    },
    "branchRelationsStructure": {
      "requiredFields": ["liuHe", "sanHe", "sanHui", "liuChong", "sanXing", "liuHai", "summary"]
    },
    "hiddenStemsStructure": {
      "requiredFields": ["year", "month", "day", "hour"],
      "valueType": "array"
    }
  },
  "validationRules": {
    "dateFormats": [
      "YYYY-MM-DD",
      "YYYY/MM/DD"
    ],
    "timeFormats": [
      "HH:mm"
    ],
    "validStems": ["甲", "乙", "丙", "丁", "戊", "己", "庚", "辛", "壬", "癸"],
    "validBranches": ["子", "丑", "寅", "卯", "辰", "巳", "午", "未", "申", "酉", "戌", "亥"],
    "validElements": ["wood", "fire", "earth", "metal", "water"],
    "validYinYang": ["yang", "yin"]
  },
  "testDataNotes": {
    "yearPillarCalculation": "以立春為界，立春前屬於前一年",
    "monthPillarCalculation": "以節氣為界換月，非農曆月份",
    "dayPillarCalculation": "基於1900年1月1日甲戌日為基準",
    "hourPillarCalculation": "23:00-00:59 為子時，可能跨日"
  }
