  "descriptions": {
    "甲子旬": {
      "name": "甲子旬",
      "overview": "甲子為六十甲子之首，萬物之始，生機萌動。甲子旬包含甲子至癸酉十個干支，為旬首之始。",
      "kongWang": "戌亥空亡",
      "meaning": "旬首為甲，甲為天干之首，主生發、開創。甲子旬主事物初始，氣機初動，宜於開創事業、開始新的計劃。",
      "characteristics": [
        "主事物之始，氣機初萌",
        "甲木藏於子水之中，水生木旺",
        "戌亥為空亡，主虛空、缺失"
      ]
    },
    "甲戌旬": {
      "name": "甲戌旬",
      "overview": "甲戌旬包含甲戌至癸未十個干支，為第二旬。",
      "kongWang": "申酉空亡",
      "meaning": "甲戌旬中甲木藏於戌土，土中有火，主收藏、積蓄。此旬主事物穩固，根基紮實。",
      "characteristics": [
        "甲木入戌土庫中，主收藏",
        "戌為火庫，內含火氣",
        "申酉為空亡，金氣空缺"
      ]
    },
    "甲申旬": {
      "name": "甲申旬",
      "overview": "甲申旬包含甲申至癸巳十個干支，為第三旬。",
      "kongWang": "午未空亡",
      "meaning": "甲申旬中甲木逢申金，金克木，主變動、轉化。此旬主事物變化較多，需注意應對。",
      "characteristics": [
        "甲木逢申金相克，主變動",
        "申為驛馬，主奔波",
        "午未為空亡，火氣空缺"
      ]
    },
    "甲午旬": {
      "name": "甲午旬",
      "overview": "甲午旬包含甲午至癸卯十個干支，為第四旬。",
      "kongWang": "辰巳空亡",
      "meaning": "甲午旬中甲木生午火，火氣炎上，主光明、顯達。此旬主事物發展順暢，易有成就。",
      "characteristics": [
        "甲木生午火，木火通明",
        "午為文明之象，主顯達",
        "辰巳為空亡，土氣空缺"
      ]
    },
    "甲辰旬": {
      "name": "甲辰旬",
      "overview": "甲辰旬包含甲辰至癸丑十個干支，為第五旬。",
      "kongWang": "寅卯空亡",
      "meaning": "甲辰旬中甲木入辰土濕庫，水氣蘊藏，主潛伏、孕育。此旬主事物暗中發展，需要耐心等待。",
      "characteristics": [
        "甲木入辰為濕庫，水氣潛藏",
        "辰為水庫，主孕育",
        "寅卯為空亡，木氣空缺"
      ]
    },
    "甲寅旬": {
      "name": "甲寅旬",
      "overview": "甲寅旬包含甲寅至癸亥十個干支，為第六旬。",
      "kongWang": "子丑空亡",
      "meaning": "甲寅旬中甲木坐寅木祿地，木氣旺盛，主生長、繁榮。此旬主事物發展迅速，生機勃勃。",
      "characteristics": [
        "甲木坐寅為得祿，木氣最旺",
        "寅為甲木本氣，力量強盛",
        "子丑為空亡，水氣空缺"
      ]
    }
  }
}