  "calculationRules": {
    "overview": "值符值使是奇門遁甲排盤的核心，值符代表天盤主導力量，值使代表人盤主導力量",
    "zhifu": {
      "principle": "值符隨天盤星轉動，代表天時",
      "step1": "確定當前局數（陽遁一局至九局，陰遁一局至九局）",
      "step2": "根據局數確定值符星",
      "step3": "根據時干確定值符所在宮位",
      "step4": "值符帶動九星在九宮中飛布",
      "formula": "值符星 = 局數對應之星（陽遁順數，陰遁逆數）"
    },
    "zhishi": {
      "principle": "值使隨門轉動，代表人和",
      "step1": "確定當前局數",
      "step2": "根據局數確定值使門",
      "step3": "根據時支確定值使所在宮位",
      "step4": "值使帶動八門在八宮中飛布",
      "formula": "值使門 = 局數對應之門（陽遁順數，陰遁逆數）"
    },
    "relationship": {
      "description": "值符與值使的關係",
      "zhifu_controls": "天盤九星的排列",
      "zhishi_controls": "人盤八門的排列",
      "interaction": "值符值使共同決定時盤格局，值符主天時，值使主人和，地盤主地利"
    }
  },

