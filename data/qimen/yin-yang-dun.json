  "descriptions": {
    "陽遁": {
      "name": "陽遁",
      "meaning": "陽遁主進取、發展、積極",
      "direction": "順行",
      "period": "冬至後至夏至前",
      "element": "陽氣上升",
      "characteristics": [
        "主動積極",
        "利於進取發展",
        "陽氣充沛",
        "萬物生長"
      ],
      "usage": "冬至後陽氣漸長，用陽遁順布三奇六儀"
    },
    "陰遁": {
      "name": "陰遁",
      "meaning": "陰遁主保守、收斂、穩重",
      "direction": "逆行",
      "period": "夏至後至冬至前",
      "element": "陰氣上升",
      "characteristics": [
        "主守斂藏",
        "利於防守穩固",
        "陰氣漸盛",
        "萬物收藏"
      ],
      "usage": "夏至後陰氣漸長，用陰遁逆布三奇六儀"
    }
  },
